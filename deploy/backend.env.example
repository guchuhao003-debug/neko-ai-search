APP_NAME=neko-ai-search
APP_ENV=production
FRONTEND_ORIGINS=https://conda.asia

# Caddy runs in Docker and forwards the original client IP to backend.
TRUSTED_PROXY_IPS=172.16.0.0/12

# Fill these on the server. Do not commit real keys.
TAVILY_API_KEY=
DEEPSEEK_API_KEY=

TAVILY_MAX_RESULTS=8
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TEMPERATURE=0.2
DEEPSEEK_THINKING=true
DEEPSEEK_REASONING_EFFORT=
USE_MOCK_AI=false

AI_MAX_CONTEXT_SOURCES=6
AI_MAX_SOURCE_CONTENT_CHARS=900
AI_FAST_ANSWER=true
AI_GENERATE_RELATED_WITH_AI=false

COST_GUARD_BACKEND=sqlite
COST_GUARD_SQLITE_PATH=/app/data/cost_guard.sqlite3
ACCOUNT_DB_PATH=/app/data/accounts.sqlite3

SESSION_COOKIE_NAME=neko_session
SESSION_TTL_SECONDS=604800
SESSION_COOKIE_SECURE=true

ADMIN_EMAILS=935070021@qq.com
CREDIT_INITIAL_BALANCE=20
RATE_LIMIT_PER_MINUTE=10
AUTH_RATE_LIMIT_PER_MINUTE=8
IP_DAILY_EXTERNAL_QUOTA=50
GLOBAL_DAILY_EXTERNAL_QUOTA=1000
IP_CONCURRENT_STREAMS=2

SECURITY_BLOCKED_TERMS_PATH=/app/app/security/blocked_terms.txt
SEARCH_CACHE_TTL_SECONDS=1800
