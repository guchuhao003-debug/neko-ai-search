APP_NAME=neko-ai-search
APP_ENV=production

# Browser origins that are allowed to send credentialed requests to the API.
FRONTEND_ORIGINS=https://your-domain.com

# Only these direct proxy IPs or CIDRs may provide x-forwarded-for.
TRUSTED_PROXY_IPS=127.0.0.1

# External providers. Never commit real keys.
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=8
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TEMPERATURE=0.2
DEEPSEEK_THINKING=true
DEEPSEEK_REASONING_EFFORT=

# Development fallback. Keep false in production.
USE_MOCK_AI=false

# AI answer cost and latency controls.
AI_MAX_CONTEXT_SOURCES=6
AI_MAX_SOURCE_CONTENT_CHARS=900
AI_FAST_ANSWER=true
AI_GENERATE_RELATED_WITH_AI=false

# Persistent local SQLite files.
COST_GUARD_BACKEND=sqlite
COST_GUARD_SQLITE_PATH=/app/data/cost_guard.sqlite3
ACCOUNT_DB_PATH=/app/data/accounts.sqlite3

# Session cookies. Set secure=true behind HTTPS.
SESSION_COOKIE_NAME=neko_session
SESSION_TTL_SECONDS=604800
SESSION_COOKIE_SECURE=true

# Comma-separated admin account emails.
ADMIN_EMAILS=admin@example.com

# Credit and quota controls.
CREDIT_INITIAL_BALANCE=20
RATE_LIMIT_PER_MINUTE=10
AUTH_RATE_LIMIT_PER_MINUTE=8
IP_DAILY_EXTERNAL_QUOTA=50
GLOBAL_DAILY_EXTERNAL_QUOTA=1000
IP_CONCURRENT_STREAMS=2

# Security and cache controls.
SECURITY_BLOCKED_TERMS_PATH=/app/app/security/blocked_terms.txt
SEARCH_CACHE_TTL_SECONDS=1800
